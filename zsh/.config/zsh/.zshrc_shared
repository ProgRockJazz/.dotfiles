# Shared zshrc config between all devices. Use by adding:
# if [ -f $HOME/.config/zsh/.zshrc_shared ]; then
#	 source $HOME/.config/zsh/.zshrc_shared
# fi
#
# to machine's ~/.zshrc

# Setup completion stuff
source $HOME/.config/zsh/.completion.zsh
# Add fuzzy fzf bindings
eval "$(fzf --zsh)"
autoload -U compinit; compinit
_comp_options+=(globdots)
zmodload zsh/complist

# Add cute theme :)
eval "$(oh-my-posh init zsh --config $HOME/.config/omp-themes/M365Princess.omp.json)"

# setup directory stack
setopt AUTO_PUSHD           # Push the current directory visited on the stack.
setopt PUSHD_IGNORE_DUPS    # Do not store duplicates in the stack.
setopt PUSHD_SILENT         # Do not print the directory stack after pushd or popd.
alias d='dirs -v'
for index ({1..9}) alias "$index"="cd +${index}"; unset index


# History config
setopt INC_APPEND_HISTORY # Immediately push history to file on every command
HISTSIZE=50000
SAVEHIST=50000
HISTFILE=~/.zsh_history

# Editor config
alias vim=nvim
export EDITOR=nvim

# Init zoxide
eval "$(zoxide init zsh)"

# Emacs mode at prompt
bindkey -e 

